rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Role Checks (Assuming 'role' field exists on the user document)
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    function isSuperAdmin() {
      return hasRole('super_admin');
    }

    function isOrderManager() {
      return hasRole('order_manager') || isSuperAdmin();
    }

    function isContentManager() {
      return hasRole('content_manager') || isSuperAdmin();
    }

    function isAdmin() {
      return isSuperAdmin() || isOrderManager() || isContentManager();
    }

    // Validation Helpers
    function isValidSuperCollection() {
      return request.resource.data.superCollection in ['casual', 'sport'];
    }

    function isValidCategory() {
      return request.resource.data.category in ['male', 'female', 'unisex'];
    }

    function isValidGender() {
      return request.resource.data.gender in ['male', 'female', 'unisex'];
    }

    // --- Collection Rules ---

    // Users Collection
    match /users/{userId} {
      // Users can read/write their own profile
      // Admins need access to user data for orders/management
      allow read: if isOwner(userId) || isOrderManager() || isSuperAdmin();
      allow create: if isAuthenticated(); // For sign up
      allow update: if isOwner(userId) || isSuperAdmin(); // Only super admin can change roles
      allow delete: if isSuperAdmin();
    }

    // Wishlists
    match /wishlists/{userId} {
      allow read, write: if isOwner(userId);
    }

      // Products (Public Read, Admin Write, Allow Inventory Updates)
      match /products/{productId} {
         allow read: if true;
         allow create: if isAdmin() 
           && isValidCategory()
           && request.resource.data.collectionId is string
           && request.resource.data.name is string
           && request.resource.data.price is number;
         allow update: if isAdmin()
           && (isValidCategory() || request.resource.data.category == resource.data.category)
           || (
             // Allow updating inventory field even if not admin (for order processing)
             (request.resource.data.keys().hasOnly(['inventory', 'updatedAt']) || 
              request.resource.data.keys().hasOnly(['inventory']))
           );
         allow delete: if isAdmin();
       }

    // Categories Collection - DEPRECATED
    // Categories are now hardcoded (Men/Women) and not stored in Firestore
    // This rule is kept for backwards compatibility only
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false; // No longer allowed to create/modify categories
    }

    // Homepage Content (Public Read, Admin Write)
    match /homepage_content/{contentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // World Sections (Public Read, Admin Write) - for hero and other world page sections
    match /world_sections/{sectionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // World Mosaic (Public Read, Admin Write)
    match /world_mosaic/{contentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Banners (Public Read, Admin Write)
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

     // Category Highlights (Public Read, Admin Write)
     match /category_highlights/{highlightId} {
       allow read: if true;
       allow write: if isAdmin();
     }

     // What's New Items (Public Read, Admin Write)
     match /whats_new/{itemId} {
       allow read: if true;
       allow write: if isAdmin();
     }

     // Palette Items (Public Read, Admin Write)
     match /palettes/{itemId} {
       allow read: if true;
       allow write: if isAdmin();
     }

     // Highlight Items (Public Read, Admin Write)
     match /highlights/{itemId} {
       allow read: if true;
       allow write: if isAdmin();
     }

     // Homepage Sections (Public Read, Admin Write)
     // New collection for managing homepage components (hero, sport, casual, style, world, stage, newsletter)
     match /homepage_sections/{sectionId} {
       allow read: if true;
       allow write: if isAdmin();
     }

     // Campaign Sections (Public Read, Admin Write)
     // Collection for managing campaign page components
     match /campaign_sections/{sectionId} {
       allow read: if true;
       allow write: if isAdmin();
     }

      // Collections (Public Read, Admin Write)
      // Collections must have a superCollection field (casual/sport)
      match /collections/{collectionId} {
        allow read: if true;
        allow create: if isAdmin()
         && isValidSuperCollection()
         && request.resource.data.name is string
         && request.resource.data.slug is string
         && request.resource.data.image is string;
        allow update: if isAdmin()
         && (request.resource.data.superCollection in ['casual', 'sport'] || request.resource.data.superCollection == resource.data.superCollection);
        allow delete: if isAdmin();
      }

    // Campaigns (Public Read, Admin Write)
    match /campaigns/{campaignId} {
      allow read: if true;
      allow write: if isAdmin();
    }

     // Orders
     match /orders/{orderId} {
       // Users see their own orders
       // Order Managers & Super Admins see all
       allow read: if isOwner(resource.data.userId) 
         || isOrderManager() 
         || (resource.data.email == request.resource.data.email);

       // Users can create orders (authenticated or guest with email)
       allow create: if isAuthenticated()
         || (request.resource.data.userId == 'guest' && request.resource.data.email is string);

       // Only Admins can update order status
       // (Webhook uses Admin SDK which bypasses rules)
       allow update: if isOrderManager();
     }

    // World Content (Articles/Events)
    match /content/{contentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Audit Logs (Restricted)
    match /audit_logs/{logId} {
      allow read: if isSuperAdmin() || isOrderManager() || isContentManager();
      allow create: if isSuperAdmin() || isOrderManager() || isContentManager(); // Admins create logs on action
      allow update, delete: if false; // Logs are immutable
    }

    // Settings (App Configuration)
    match /settings/{settingId} {
      allow read: if true; // Or restricted depending on sensitivity
      allow write: if isSuperAdmin();
    }

    // Analytics (Admin Read)
    match /analytics/{docId} {
      allow read, write: if isAdmin();
    }

    // Newsletter Subscribers
    match /subscribers/{email} {
      // Anyone can read (for public subscriber count if needed)
      allow read: if true;
      // Only server/admin can write (subscription goes through API)
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // Discount Codes
    match /discounts/{discountId} {
      // Admins can manage all discounts
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }
  }
}